{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": "frontend/frontend",
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "backend/app/main.py",
      "routePrefix": "/backend",
      "memory": 2048,
      "maxDuration": 300,
      "includeFiles": [
        "data/**",
        "backend/data/**",
        "backend/models/**",
        "backend/static/**",
        "backend/assets/**"
      ]
    }
  }
}
